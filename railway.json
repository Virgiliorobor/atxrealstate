{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd _uidev/demo && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd _uidev/demo && node dist/server/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
