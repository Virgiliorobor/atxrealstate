# Required
ANTHROPIC_API_KEY=your_key_here

# Server port (Railway sets PORT automatically; 19877 is the local dev default)
PORT=19877

# Storage mode: local (filesystem) or github (GitHub Contents API for Netlify)
STORAGE_MODE=local

# Required when STORAGE_MODE=github
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=

# Optional overrides
ANTHROPIC_MODEL=
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_MAX_TOOL_ITERATIONS=25
VITE_AGENCY_WEBSITE_URL=/the_agency_website/
