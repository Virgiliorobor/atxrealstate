# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Local default: 19877
PORT=19877

# ── Session (production /app login) ───────────────────────────────────────────
# Signs session cookies. Must be a long random string (32+ chars).
# If unset, a random value is generated on each restart — sessions will break
# on every redeploy. Set this in Railway Variables and keep a copy here locally.
AGENCY_SESSION_SECRET=

# ── Agency repo root ──────────────────────────────────────────────────────────
# Default when running from _uidev/demo: two levels up
AGENCY_ROOT=

# ── Claude model ──────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_MAX_TOOL_ITERATIONS=25

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_AGENCY_WEBSITE_URL=/the_agency_website/

# ── Storage ───────────────────────────────────────────────────────────────────
# local  → writes to filesystem (ephemeral on Railway — lost on redeploy)
# github → writes back to GitHub repo as commits (durable)
STORAGE_MODE=local

# Required when STORAGE_MODE=github
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=
# Optional: subdirectory inside repo if agency files aren't at the root
GITHUB_BASE_PATH=
