ANTHROPIC_API_KEY=
# Optional: repo root containing AI_README.md, 00_orchestrator/, _database/, etc.
# Default when running from _uidev/demo: two levels up (Realstateagency/)
AGENCY_ROOT=
# Optional model override
ANTHROPIC_MODEL=
# Optional output cap (Anthropic requires max_tokens on each call)
ANTHROPIC_MAX_TOKENS=8192
# Optional public link shown in demo UI
VITE_AGENCY_WEBSITE_URL=/the_agency_website/

# Storage mode: local (filesystem) or github (GitHub Contents API)
STORAGE_MODE=local
# Required when STORAGE_MODE=github
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=
# Optional subdirectory inside repo for agency-system files
GITHUB_BASE_PATH=
